{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "raycast-extension",
  "title": "ZBD Agent Wallet",
  "description": "Run zbdw wallet commands from Raycast with structured JSON output",
  "icon": "icon.png",
  "author": "andrerfneves",
  "categories": [
    "Developer Tools",
    "Finance"
  ],
  "license": "MIT",
  "platforms": [
    "macOS"
  ],
  "commands": [
    {
      "name": "init",
      "title": "Zbdw Init",
      "description": "Initialize wallet identity",
      "mode": "view"
    },
    {
      "name": "info",
      "title": "Zbdw Info",
      "description": "Show wallet metadata",
      "mode": "view"
    },
    {
      "name": "balance",
      "title": "Zbdw Balance",
      "description": "Get wallet balance",
      "mode": "view"
    },
    {
      "name": "receive",
      "title": "Zbdw Receive",
      "description": "Create invoice or static charge",
      "mode": "view"
    },
    {
      "name": "send",
      "title": "Zbdw Send",
      "description": "Send payment",
      "mode": "view"
    },
    {
      "name": "payments",
      "title": "Zbdw Payments",
      "description": "List payment history",
      "mode": "view"
    },
    {
      "name": "payment",
      "title": "Zbdw Payment",
      "description": "Get payment detail",
      "mode": "view"
    },
    {
      "name": "paylink",
      "title": "Zbdw Paylink",
      "description": "Manage paylinks",
      "mode": "view"
    },
    {
      "name": "withdraw",
      "title": "Zbdw Withdraw",
      "description": "Manage LNURL withdraw",
      "mode": "view"
    },
    {
      "name": "onchain",
      "title": "Zbdw Onchain",
      "description": "Manage onchain payouts",
      "mode": "view"
    },
    {
      "name": "fetch",
      "title": "Zbdw Fetch",
      "description": "Run L402-aware fetch",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "apiKey",
      "title": "ZBD API Key",
      "description": "Used as ZBD_API_KEY for zbdw",
      "type": "password",
      "required": true
    },
    {
      "name": "cliPath",
      "title": "zbdw Path",
      "description": "Optional absolute path override for zbdw binary",
      "type": "textfield",
      "required": false
    },
    {
      "name": "apiBaseUrl",
      "title": "API Base URL",
      "description": "Optional ZBD_API_BASE_URL override",
      "type": "textfield",
      "required": false
    },
    {
      "name": "aiBaseUrl",
      "title": "AI Base URL",
      "description": "Optional ZBD_AI_BASE_URL override",
      "type": "textfield",
      "required": false
    }
  ],
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "lint": "ray lint",
    "fix-lint": "ray lint --fix",
    "test": "tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "verify:contracts": "node ./scripts/verify-contracts.mjs"
  },
  "dependencies": {
    "@raycast/api": "^1.94.0",
    "@raycast/utils": "^1.10.1"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.6",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "eslint": "^8.57.1",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
